{
  "name": "@e-tady-dokotera/api",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "// dev": "Runs NestJS directly via ts-node with path alias support (@ -> src/)",
    "dev": "ts-node -r tsconfig-paths/register src/main.ts",
    "// build": "Compiles TypeScript to dist/ using the build-specific tsconfig (excludes tests)",
    "build": "tsc -p tsconfig.build.json",
    "// db:migrate": "Creates and applies a new migration in development/ This tells Prisma to create the table in PostgreSQL.",
    "db:migrate": "npx prisma migrate dev --name init",
    "// db:generate": "Generates the Prisma client from the schema (run after schema changes)",
    "db:generate": "npx prisma generate",
    "// db:migrate:deploy": "Applies pending migrations non-interactively — use in CI and production",
    "db:migrate:deploy": "prisma migrate deploy",
    "// test": "Unit tests — no DB or Redis required, all deps are mocked",
    "test": "jest --config jest.config.ts",
    "// test:integration": "Integration tests — requires docker compose -f docker-compose.test.yml up -d",
    "test:integration": "jest --config jest.integration.config.ts --runInBand",
    "// test:coverage": "Unit tests with coverage report in coverage/unit/",
    "test:coverage": "jest --config jest.config.ts --coverage",
    "lint": "eslint src/",
    "// db:seed": "Seeds the database with 20 doctors + 3 patients for local development",
    "db:seed": "npx prisma db seed"
  },
  "dependencies": {
    "@bull-board/api": "^6.20.3",
    "@bull-board/express": "^6.20.3",
    "@bull-board/nestjs": "^6.20.3",
    "@nest-lab/throttler-storage-redis": "^1.2.0",
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/common": "^11.1.14",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.1.14",
    "@nestjs/event-emitter": "^3.0.1",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.14",
    "@nestjs/platform-socket.io": "^11.1.16",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/websockets": "^11.1.16",
    "@prisma/adapter-pg": "^7.4.2",
    "@prisma/client": "^7.4.2",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.70.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "cookie-parser": "^1.4.7",
    "express-basic-auth": "^1.2.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.0",
    "luxon": "^3.7.2",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "socket.io": "^4.8.3",
    "tsconfig-paths": "^4.2.0"
  },
  "devDependencies": {
    "@nestjs/testing": "^11.1.16",
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/luxon": "^3.7.1",
    "@types/node": "^25.3.2",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^7.2.0",
    "dotenv": "^17.3.1",
    "jest": "^30.2.0",
    "prisma": "^7.4.2",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "@prisma/engines",
      "bcrypt",
      "msgpackr-extract",
      "prisma"
    ]
  }
}
